{
  "name": "@birchill/jpdict-idb",
  "version": "3.3.0",
  "description": "Download and lookup jpdict data using IndexedDB",
  "author": "Brian Birtles",
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint --type-aware .",
    "test": "vitest run",
    "prepublishOnly": "tsdown",
    "prepare": "husky",
    "ci:publish": "pnpm changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birchill/jpdict-idb.git"
  },
  "bugs": {
    "url": "https://github.com/birchill/jpdict-idb/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "homepage": "https://github.com/birchill/jpdict-idb#readme",
  "dependencies": {
    "@birchill/json-equalish": "^2.0.0",
    "@birchill/kanji-component-string-utils": "^2.0.0",
    "@birchill/normal-jp": "^1.5.2",
    "idb": "^8.0.0",
    "superstruct": "^2.0.2"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@types/node": "24.13.3",
    "@vitest/browser-playwright": "4.1.10",
    "fetch-mock": "12.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "tsdown": "0.22.9",
    "tslib": "2.8.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "pnpm": ">=11"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "engines": {}
  }
}
